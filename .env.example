# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=surveyagent

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long-change-in-production

# LLM Providers — OpenAI is required (also used for TTS), others are optional
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: enable Anthropic and/or Gemini as alternative LLM providers
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

RESEND_API_KEY=your-resend-api-key
FRONTEND_URL=http://localhost:5174
