# MongoDB — docker compose uses local MongoDB automatically, override for Atlas/remote
MONGO_URI=mongodb://localhost:27017/surveyagent
MONGO_DB_NAME=surveyagent

# JWT Configuration — change this to a random secret
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long-change-in-production

# LLM Providers — at least one is required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: enable Anthropic and/or Gemini as alternative LLM providers
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key

# Optional: email notifications via Resend
# RESEND_API_KEY=your-resend-api-key

FRONTEND_URL=http://localhost:8000

# Survey Limits — 0 = unlimited (default for self-hosted/dev)
MAX_SURVEYS_PER_USER=0
BYPASS_LIMIT_EMAILS=

# Interview Abandonment — minutes of inactivity before marking as abandoned (0 = disabled)
INTERVIEW_ABANDON_TIMEOUT_MINUTES=120
