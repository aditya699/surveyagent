{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "server.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "client",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5174"],
      "port": 5174,
      "cwd": "client"
    }
  ]
}
